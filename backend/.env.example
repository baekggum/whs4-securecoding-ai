# PostgreSQL connection string used by Prisma and the session store
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tiny_secondhand?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS + Socket.IO)
FRONTEND_ORIGIN="http://localhost:5173"

# Session
SESSION_SECRET="change-me-to-a-long-random-string"
SESSION_COOKIE_NAME="tsp.sid"
# 7 days, in milliseconds
SESSION_MAX_AGE_MS=604800000

# CSRF (double-submit cookie secret)
CSRF_SECRET="change-me-to-a-different-long-random-string"

# Set to "true" only when serving over HTTPS (production). When true,
# session/csrf cookies get Secure + the app trusts the first proxy hop.
COOKIE_SECURE=false

# Report thresholds — how many distinct reports before auto-block/dormant
PRODUCT_REPORT_THRESHOLD=5
USER_REPORT_THRESHOLD=5

# bcrypt cost factor
BCRYPT_SALT_ROUNDS=12
