# =============================================================================
# docker-compose.yml 전용 환경변수 (루트 .env)
#   cp .env.example .env   후 시크릿 3개(POSTGRES_PASSWORD, SESSION_SECRET,
#   CSRF_SECRET)를 반드시 실제 값으로 교체하세요.
#
# 로컬 개발 서버용 환경변수는 이 파일이 아니라 backend/.env.example /
# frontend/.env.example 을 사용합니다.
# =============================================================================

# --- PostgreSQL (postgres 컨테이너 + backend DATABASE_URL 조립에 사용) -------
POSTGRES_USER=postgres
# 필수. 예: openssl rand -hex 16
# 주의: 이 값은 DATABASE_URL에 URL 인코딩 없이 그대로 보간되므로 URL 예약문자
# (@ : / ? # 등) 없이 hex/영숫자만 사용할 것.
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=tiny_secondhand

# --- 공개 접속 지점 -----------------------------------------------------------
# 호스트에서 frontend(nginx)를 노출할 포트 → http://localhost:8080
HTTP_PORT=8080
# 브라우저가 실제로 접속하는 오리진. backend의 FRONTEND_ORIGIN(CORS/Socket.IO
# 허용 오리진)으로 전달됨. 도메인 배포 시 예: https://app.example.com
# (후행 슬래시 없이, HTTP_PORT를 바꾸면 여기 포트도 함께 변경)
PUBLIC_ORIGIN=http://localhost:8080

# --- 세션 / CSRF 시크릿 (필수, 각각 다른 랜덤 문자열, 최소 16자) ----------------
# 생성 예: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
CSRF_SECRET=change-me-to-a-different-long-random-string

# --- 쿠키 ---------------------------------------------------------------------
# true는 HTTPS로 서비스할 때만(앞단에 TLS 종료 프록시가 있을 때) 설정.
# 평문 HTTP(기본 localhost 구성)에서 true로 두면 브라우저가 Secure 쿠키를
# 조용히 버려서 로그인이 전부 실패합니다.
COOKIE_SECURE=false
SESSION_COOKIE_NAME=tsp.sid
# 세션 만료 (기본 7일, ms)
SESSION_MAX_AGE_MS=604800000

# --- 운영 파라미터 (backend/src/env.ts 기본값과 동일) --------------------------
# 신고 자동 차단/휴면 임계치
PRODUCT_REPORT_THRESHOLD=5
USER_REPORT_THRESHOLD=5
# bcrypt cost factor (10~15)
BCRYPT_SALT_ROUNDS=12
# 포인트 이코노미
SIGNUP_BONUS_POINTS=10000
MAX_TRANSFER_AMOUNT=1000000
